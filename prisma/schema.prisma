generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SeoPageType {
  HOME
  CONTACT
  STATIC_PAGE
  PRODUCT_CATEGORY
  PRODUCT
  BLOG
  NEWS
}

enum StaticPageTemplateType {
  DEFAULT
  FULL_HTML
  LANDING_PAGE
}

enum ContactMessageStatus {
  NEW
  READ
  REPLIED
  SPAM
}

enum IntegrationType {
  ZALO_OA
  HOTLINE
  SMTP
  TELEGRAM
  FACEBOOK
  OTHER
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  OTHER
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  email        String    @unique
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  uploadedMedia      Media[]
  createdStaticPages StaticPage[] @relation("StaticPageCreatedBy")
  updatedStaticPages StaticPage[] @relation("StaticPageUpdatedBy")
  createdProducts    Product[]    @relation("ProductCreatedBy")
  updatedProducts    Product[]    @relation("ProductUpdatedBy")
  createdBlogs       Blog[]       @relation("BlogCreatedBy")
  updatedBlogs       Blog[]       @relation("BlogUpdatedBy")
  createdNews        News[]       @relation("NewsCreatedBy")
  updatedNews        News[]       @relation("NewsUpdatedBy")
  assignedContacts   ContactMessage[] @relation("ContactAssignedTo")
}

model Media {
  id         Int       @id @default(autoincrement())
  fileName   String
  filePath   String
  fileType   String?
  mimeType   String?
  fileSize   Int?
  title      String?
  altText    String?
  uploadedBy Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  uploader User? @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  websiteSettingLogos       WebsiteSetting[] @relation("WebsiteSettingLogo")
  websiteSettingFooterLogos WebsiteSetting[] @relation("WebsiteSettingFooterLogo")
  websiteSettingFavicons    WebsiteSetting[] @relation("WebsiteSettingFavicon")
  websiteSettingOgImages    WebsiteSetting[] @relation("WebsiteSettingOgImage")

  seoOgImages      SeoPage[] @relation("SeoPageOgImage")
  seoTwitterImages SeoPage[] @relation("SeoPageTwitterImage")

  staticPageFeaturedImages StaticPage[] @relation("StaticPageFeaturedImage")
  staticPageBannerImages   StaticPage[] @relation("StaticPageBannerImage")

  productCategoryImages  ProductCategory[] @relation("ProductCategoryImage")
  productCategoryBanners ProductCategory[] @relation("ProductCategoryBannerImage")

  productThumbnails Product[] @relation("ProductThumbnail")
  productBanners    Product[] @relation("ProductBannerImage")

  blogThumbnails Blog[] @relation("BlogThumbnail")
  blogBanners    Blog[] @relation("BlogBannerImage")

  newsThumbnails News[] @relation("NewsThumbnail")
  newsBanners    News[] @relation("NewsBannerImage")

  slideshows Slideshow[]
}

model Slideshow {
  id        Int      @id @default(autoincrement())
  title     String?
  link      String?
  altText   String?
  imageId   Int
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  image Media @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([sortOrder])
  @@index([isActive])
  @@index([imageId])
}

model WebsiteSetting {
  id              Int      @id @default(autoincrement())
  siteName        String
  siteSlogan      String?
  siteDescription String?
  logoId          Int?
  footerLogoId    Int?
  faviconId       Int?
  email           String?
  hotline         String?
  hotlineDisplay  String?
  zaloPhone       String?
  address         String?
  googleMapIframe String?
  facebookUrl     String?
  youtubeUrl      String?
  tiktokUrl       String?
  linkedinUrl     String?
  instagramUrl    String?
  copyrightText   String?
  defaultLanguage String?  @default("vi")
  ogImageId       Int?
  headerScripts   String?
  bodyScripts     String?
  footerScripts   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  logo       Media? @relation("WebsiteSettingLogo", fields: [logoId], references: [id], onDelete: SetNull)
  footerLogo Media? @relation("WebsiteSettingFooterLogo", fields: [footerLogoId], references: [id], onDelete: SetNull)
  favicon    Media? @relation("WebsiteSettingFavicon", fields: [faviconId], references: [id], onDelete: SetNull)
  ogImage    Media? @relation("WebsiteSettingOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)
}

model IntegrationSetting {
  id        Int             @id @default(autoincrement())
  type      IntegrationType
  name      String
  valueJson Json
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SeoPage {
  id                 Int         @id @default(autoincrement())
  pageType           SeoPageType
  entityId           Int?
  routePath          String?
  metaTitle          String?
  metaDescription    String?
  metaKeywords       String?
  canonicalUrl       String?
  robots             String?
  ogTitle            String?
  ogDescription      String?
  ogImageId          Int?
  twitterTitle       String?
  twitterDescription String?
  twitterImageId     Int?
  schemaJson         Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  ogImage      Media? @relation("SeoPageOgImage", fields: [ogImageId], references: [id], onDelete: SetNull)
  twitterImage Media? @relation("SeoPageTwitterImage", fields: [twitterImageId], references: [id], onDelete: SetNull)

  @@index([pageType, entityId])
  @@index([routePath])
}

model StaticPage {
  id              Int                    @id @default(autoincrement())
  title           String
  slug            String                 @unique
  summary         String?
  content         String?
  type            String?
  templateType    StaticPageTemplateType @default(DEFAULT)
  featuredImageId Int?
  bannerImageId   Int?
  status          PublishStatus          @default(DRAFT)
  publishedAt     DateTime?
  sortOrder       Int                    @default(0)
  showInMenu      Boolean                @default(false)
  createdBy       Int?
  updatedBy       Int?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  featuredImage Media? @relation("StaticPageFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull)
  bannerImage   Media? @relation("StaticPageBannerImage", fields: [bannerImageId], references: [id], onDelete: SetNull)

  creator User? @relation("StaticPageCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater User? @relation("StaticPageUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([sortOrder])
}

model ProductCategory {
  id            Int       @id @default(autoincrement())
  name          String
  slug          String    @unique
  description   String?
  content       String?
  imageId       Int?
  bannerImageId Int?
  sortOrder     Int       @default(0)
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  image       Media?    @relation("ProductCategoryImage", fields: [imageId], references: [id], onDelete: SetNull)
  bannerImage Media?    @relation("ProductCategoryBannerImage", fields: [bannerImageId], references: [id], onDelete: SetNull)
  products    Product[]

  @@index([isActive])
  @@index([sortOrder])
}

model Product {
  id            Int           @id @default(autoincrement())
  categoryId    Int?
  title         String
  slug          String        @unique
  sku           String?
  summary       String?
  content       String?
  price         Decimal?      @db.Decimal(12, 2)
  oldPrice      Decimal?      @db.Decimal(12, 2)
  thumbnailId   Int?
  bannerImageId Int?
  galleryJson   Json?
  isFeatured    Boolean       @default(false)
  isActive      Boolean       @default(true)
  status        PublishStatus @default(DRAFT)
  publishedAt   DateTime?
  viewCount     Int           @default(0)
  sortOrder     Int           @default(0)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  thumbnail   Media?           @relation("ProductThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  bannerImage Media?           @relation("ProductBannerImage", fields: [bannerImageId], references: [id], onDelete: SetNull)

  creator User? @relation("ProductCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater User? @relation("ProductUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  tags ProductTag[]

  @@index([categoryId])
  @@index([status])
  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([publishedAt])
}

model Blog {
  id            Int           @id @default(autoincrement())
  title         String
  slug          String        @unique
  summary       String?
  content       String?
  thumbnailId   Int?
  bannerImageId Int?
  authorName    String?
  status        PublishStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  isActive      Boolean       @default(true)
  publishedAt   DateTime?
  viewCount     Int           @default(0)
  sortOrder     Int           @default(0)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  thumbnail   Media? @relation("BlogThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  bannerImage Media? @relation("BlogBannerImage", fields: [bannerImageId], references: [id], onDelete: SetNull)

  creator User? @relation("BlogCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater User? @relation("BlogUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([isActive])
  @@index([sortOrder])
}

model News {
  id            Int           @id @default(autoincrement())
  title         String
  slug          String        @unique
  summary       String?
  content       String?
  thumbnailId   Int?
  bannerImageId Int?
  authorName    String?
  status        PublishStatus @default(DRAFT)
  isFeatured    Boolean       @default(false)
  isActive      Boolean       @default(true)
  publishedAt   DateTime?
  viewCount     Int           @default(0)
  sortOrder     Int           @default(0)
  createdBy     Int?
  updatedBy     Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  thumbnail   Media? @relation("NewsThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  bannerImage Media? @relation("NewsBannerImage", fields: [bannerImageId], references: [id], onDelete: SetNull)

  creator User? @relation("NewsCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updater User? @relation("NewsUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([isActive])
  @@index([sortOrder])
}

model ContactMessage {
  id           Int                  @id @default(autoincrement())
  fullName     String
  phone        String
  email        String?
  companyName  String?
  subject      String?
  message      String?
  serviceType  String?
  sourcePage   String?
  ipHash       String?
  userAgent    String?
  status       ContactMessageStatus @default(NEW)
  assignedTo   Int?
  noteInternal String?
  sentToZalo   Boolean              @default(false)
  sentToEmail  Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  assignee User? @relation("ContactAssignedTo", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Visit {
  id          Int        @id @default(autoincrement())
  sessionId   String?
  path        String
  referer     String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  deviceType  DeviceType?
  browser     String?
  os          String?
  country     String?
  city        String?
  ipHash      String?
  visitedAt   DateTime   @default(now())

  @@index([visitedAt])
  @@index([path])
}

model VisitDailyStat {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique
  totalVisits  Int      @default(0)
  uniqueVisits Int      @default(0)
  contactCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OnlineSession {
  id         Int      @id @default(autoincrement())
  sessionId  String   @unique
  path       String?
  ipHash     String?
  userAgent  String?
  lastSeenAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([lastSeenAt])
}

model Tag {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  slug      String       @unique
  products  ProductTag[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ProductTag {
  productId Int
  tagId     Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}